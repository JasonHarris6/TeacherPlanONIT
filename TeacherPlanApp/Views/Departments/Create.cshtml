@model TeacherPlanApp.Models.Department

<div class="container mt-4">
    <h2>Добавление кафедры</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label">Название:</label>
                    <input asp-for="Name" class="form-control" placeholder="Например: ИТиВС" />
                </div>
                <div class="form-group">
                    <input type="submit" value="Сохранить в БД" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Назад к списку</a>
                </div>
            </form>
        </div>
    </div>
</div>