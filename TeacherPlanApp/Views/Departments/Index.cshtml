@model IEnumerable<TeacherPlanApp.Models.Department>

<div class="container mt-4">
    <h2>Список кафедр</h2>

    <p>
        <a asp-action="Create" class="btn btn-primary">Добавить новую кафедру</a>
    </p>

   <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Название кафедры</th>
                <th>Действия</th> </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td> <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>